{
  "manifest_version": 3,
  "name": "Claude Notifications (browser)",
  "version": "1.0.0",
  "description": "Desktop notifications when Claude finishes or needs you in claude.ai — part of claude-notifications-everywhere.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://127.0.0.1:52741/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Notifications settings"
  }
}
