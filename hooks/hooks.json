{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook-wrapper.sh",
              "handle-hook",
              "PreToolUse"
            ],
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook-wrapper.sh",
              "handle-hook",
              "PreToolUseWatch"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook-wrapper.sh",
              "handle-hook",
              "Notification"
            ],
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook-wrapper.sh",
              "handle-hook",
              "Stop"
            ],
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook-wrapper.sh",
              "handle-hook",
              "SubagentStop"
            ],
            "timeout": 30
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook-wrapper.sh",
              "handle-hook",
              "TeammateIdle"
            ],
            "timeout": 30
          }
        ]
      }
    ]
  }
}